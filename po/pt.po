#: /mnt/3258545c-3c1f-4f3b-8dfc-8664328102bb/App-Entwicklung/Design Manager/src/pages/background.py:271
msgid ""
"First choose a custom theme (not the default one) under Shell Theme. The app "
"writes the lock screen image into that theme's style."
msgstr ""
"Escolha primeiro um tema personalizado (não o predefinido) em Tema da shell. A aplicação "
"escreve a imagem do ecrã de bloqueio no estilo desse tema."

#: /mnt/3258545c-3c1f-4f3b-8dfc-8664328102bb/App-Entwicklung/Design Manager/src/pages/background.py:283
msgid "No custom image set"
msgstr "Nenhuma imagem personalizada definida"

