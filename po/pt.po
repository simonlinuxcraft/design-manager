#: /mnt/3258545c-3c1f-4f3b-8dfc-8664328102bb/App-Entwicklung/Design
#: Manager/src/widgets/welcome.py:24
msgid ""
"Background, GTK theme, icons, cursor, fonts and the shell theme. Every "
"change takes effect immediately."
msgstr ""
"Fundo, tema GTK, ícones, cursor, tipos de letra e o tema da shell. Cada "
"alteração tem efeito imediato."

