msgstr "Apps-Schaltfläche oben"

msgid "Put the applications button at the start"
msgstr "Anwendungsschaltfläche an den Anfang setzen"

msgid "Show drives"
msgstr "Laufwerke anzeigen"

msgid "Show mounted volumes in the dock"
msgstr "Eingehängte Volumes im Dock anzeigen"

