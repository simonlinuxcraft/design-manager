"Version {new} is ready (installed: {cur}). Download and install it now? This "
"asks for the administrator password once."
msgstr ""
"Version {new} ist bereit (installiert: {cur}). Jetzt herunterladen und installieren? "
"Das fragt einmal nach dem Administrator-Passwort."

msgid "Later"
msgstr "Später"

msgid "Update"
msgstr "Aktualisieren"

#, python-brace-format
msgid "Downloading version {ver}… (enter password)"
msgstr "Version {ver} wird heruntergeladen… (Passwort eingeben)"

msgid "Updated. Please restart the app."
msgstr "Aktualisiert. Bitte die App neu starten."

msgid "Update failed or canceled."
msgstr "Update fehlgeschlagen oder abgebrochen."
