msgid "The accent color can only be set from GNOME 47 onwards."
msgstr "Die Akzentfarbe kann nur ab GNOME 47 gesetzt werden."

msgid "Color from background"
msgstr "Farbe aus dem Hintergrund"

msgid "Pick the accent color matching the current wallpaper"
msgstr "Zur aktuellen Hintergrundfarbe passende Akzentfarbe wählen"

msgid "No wallpaper found."
msgstr "Kein Hintergrund gefunden."

msgid "No matching accent color found."
msgstr "Keine passende Akzentfarbe gefunden."

