msgid ""
"This is a folder, not an archive. Please choose an archive (.tar.gz/.zip)."
msgstr ""
"Ceci est un dossier, pas une archive. Veuillez choisir une archive (.tar.gz/.zip)."

msgid "The file was not found."
msgstr "Le fichier est introuvable."

msgid "The font could not be copied."
msgstr "La police n'a pas pu être copiée."

#, python-brace-format
msgid "{sentence} Please install it on the \"{page}\" page."
msgstr "{sentence} Veuillez l'installer depuis la page \"{page}\"."

msgid ""
"This is a Windows cursor (.cur/.ani). GNOME cannot use it directly. Download "
"the Linux variant of the theme (a folder with a \"cursors\" subfolder)."
msgstr ""
"Ceci est un curseur Windows (.cur/.ani). GNOME ne peut pas l'utiliser "
"directement. Téléchargez la variante Linux du thème (un dossier contenant "
"un sous-dossier \"cursors\")."

msgid "No theme and no font found in the archive."
msgstr "Aucun thème ni police trouvé dans l'archive."

msgid "Format not supported (only .zip and .tar.*)."
msgstr "Format non pris en charge (uniquement .zip et .tar.*)."

msgid "The archive could not be extracted."
msgstr "L'archive n'a pas pu être extraite."

msgid "The archive contains unsafe paths."
msgstr "L'archive contient des chemins non sécurisés."

