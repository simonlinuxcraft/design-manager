#: /mnt/3258545c-3c1f-4f3b-8dfc-8664328102bb/App-Entwicklung/Design
#: Manager/src/widgets/monitor_arrangement.py:44
msgid ""
"Click a monitor to give it its own image. Re-apply after changing resolution "
"or layout."
msgstr ""
"Fai clic su un monitor per assegnargli un'immagine propria. Riapplica dopo "
"aver cambiato risoluzione o disposizione."

